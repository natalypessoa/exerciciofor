/* Nataly Pessoa de Paula Cruz
Faça um algoritmo que receba a idade, a altura e o peso de 10 pessoas, 	calcule e mostre:
a) A quantidade de pessoas maiores de 50 anos.
b) A média das alturas das pessoas com idade entre 10 e 20 anos.
c) A porcentagem de pessoas com peso inferior a 40 quilos.

*/
import java.util.Scanner;

public class Exercicio7 {
    public static void main(String[] args) {

Scanner teclado = new Scanner(System.in);

int idade, maiores50 = 0, pessoas = 10;
double altura, peso, somaAltura = 0;
int contAltura = 0, abaixo40 = 0;

for (int i = 0; i < pessoas; i++) {
    System.out.print("Idade: ");
    idade = teclado.nextInt();

    System.out.print("Altura: ");
    altura = teclado.nextDouble();

    System.out.print("Peso: ");
    peso = teclado.nextDouble();

    if (idade > 50) {
        maiores50++;
    }

    if (idade >= 10 && idade <= 20) {
        somaAltura += altura;
        contAltura++;
    }

    if (peso < 40) {
        abaixo40++;
    }
}

System.out.println("Maiores de 50: " + maiores50);

if (contAltura > 0) {
    System.out.println("Média alturas (10-20 anos): " + (somaAltura / contAltura));
}

System.out.println("Percentual abaixo de 40kg: " + (abaixo40 * 100.0 / pessoas) + "%");

teclado.close();
    }
}
